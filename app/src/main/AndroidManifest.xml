<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- TV support (not required — single APK for TV + mobile) -->
    <uses-feature
        android:name="android.software.leanback"
        android:required="false" />
    <uses-feature
        android:name="android.hardware.touchscreen"
        android:required="false" />

    <application
        android:name=".PramanikApp"
        android:allowBackup="false"
        android:banner="@drawable/tv_banner"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.PramanikOTT"
        android:usesCleartextTraffic="false"
        android:hardwareAccelerated="true"
        android:networkSecurityConfig="@xml/network_security_config">

        <!-- Disable Firebase auto-init to speed up startup -->
        <meta-data
            android:name="firebase_analytics_collection_deactivated"
            android:value="true" />
        <meta-data
            android:name="google_analytics_automatic_screen_reporting_enabled"
            android:value="false" />
        <meta-data
            android:name="firebase_messaging_auto_init_enabled"
            android:value="false" />

        <!-- Splash screen with animation + intro music -->
        <activity
            android:name=".SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.PramanikOTT.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
                <category android:name="android.intent.category.LEANBACK_LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Old main entry — kept for deep links -->
        <activity
            android:name=".MainActivity"
            android:exported="false" />

        <!-- Mobile UI (Compose) -->
        <activity
            android:name=".ui.mobile.MobileActivity"
            android:exported="false"
            android:theme="@style/Theme.PramanikOTT.Mobile" />

        <!-- TV UI (Leanback) -->
        <activity
            android:name=".ui.tv.TvActivity"
            android:exported="false"
            android:configChanges="orientation|screenSize|keyboard|keyboardHidden"
            android:theme="@style/Theme.PramanikOTT" />

        <!-- Video Player (shared) -->
        <activity
            android:name=".player.PlayerActivity"
            android:exported="false"
            android:configChanges="orientation|screenSize|keyboard|keyboardHidden"
            android:theme="@style/Theme.PramanikOTT.Player" />

    </application>

</manifest>
