<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Bottom controls bar -->
    <LinearLayout
        android:id="@+id/exo_bottom_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:background="@android:color/transparent"
        android:paddingBottom="8dp">

        <!-- Progress bar -->
        <androidx.media3.ui.DefaultTimeBar
            android:id="@id/exo_progress"
            android:layout_width="match_parent"
            android:layout_height="26dp"
            app:played_color="#FFE8730A"
            app:unplayed_color="#33FFFFFF"
            app:buffered_color="#66FFFFFF"
            app:scrubber_color="#FFE8730A" />

        <!-- Time + controls row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="12dp">

            <!-- Current time -->
            <TextView
                android:id="@id/exo_position"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@android:color/white"
                android:textSize="13sp"
                android:includeFontPadding="false" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" / "
                android:textColor="#99FFFFFF"
                android:textSize="13sp" />

            <!-- Duration -->
            <TextView
                android:id="@id/exo_duration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#99FFFFFF"
                android:textSize="13sp"
                android:includeFontPadding="false" />

            <!-- Spacer -->
            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <!-- Bookmark button -->
            <ImageButton
                android:id="@+id/exo_bookmark"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@android:drawable/btn_star_big_off"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:contentDescription="Bookmark"
                android:tint="@android:color/white"
                android:layout_marginEnd="4dp" />

            <!-- Speed button -->
            <ImageButton
                android:id="@+id/exo_playback_speed"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@android:drawable/ic_media_ff"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:contentDescription="Speed"
                android:tint="@android:color/white"
                android:layout_marginEnd="4dp" />

            <!-- Fullscreen / settings removed — no confusing audio track -->
        </LinearLayout>
    </LinearLayout>

    <!-- Center play/pause/next/prev controls -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Rewind 10s -->
        <ImageButton
            android:id="@id/exo_rew"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:tint="@android:color/white"
            android:contentDescription="Rewind" />

        <!-- Play/Pause -->
        <ImageButton
            android:id="@id/exo_play_pause"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:layout_marginHorizontal="24dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:tint="@android:color/white"
            android:contentDescription="Play/Pause" />

        <!-- Forward 10s -->
        <ImageButton
            android:id="@id/exo_ffwd"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:tint="@android:color/white"
            android:contentDescription="Forward" />
    </LinearLayout>

</FrameLayout>
