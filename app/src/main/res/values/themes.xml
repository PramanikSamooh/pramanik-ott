<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base TV theme (Leanback) -->
    <style name="Theme.PramanikOTT" parent="Theme.Leanback">
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:colorPrimary">@color/saffron</item>
        <item name="android:colorPrimaryDark">@color/saffron_dark</item>
        <item name="android:colorAccent">@color/gold</item>
        <item name="android:windowBackground">@color/background</item>
        <item name="defaultBrandColor">@color/saffron</item>
        <item name="defaultSearchColor">@color/saffron</item>
    </style>

    <!-- Mobile theme (used by MobileActivity — Compose handles actual theming) -->
    <style name="Theme.PramanikOTT.Mobile" parent="Theme.AppCompat.NoActionBar">
        <item name="android:windowBackground">@color/background</item>
        <item name="android:statusBarColor">@color/background</item>
        <item name="android:navigationBarColor">@color/surface</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <!-- Splash theme -->
    <style name="Theme.PramanikOTT.Splash" parent="Theme.AppCompat.NoActionBar">
        <item name="android:windowBackground">@drawable/splash_background</item>
        <item name="android:statusBarColor">@color/background</item>
        <item name="android:navigationBarColor">@color/background</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <!-- Player theme (immersive fullscreen) -->
    <style name="Theme.PramanikOTT.Player" parent="Theme.AppCompat.NoActionBar">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowBackground">@android:color/black</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>

</resources>
