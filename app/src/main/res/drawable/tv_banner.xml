<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Background -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#1A1A2E" />
        </shape>
    </item>
    <!-- Saffron accent bar at top -->
    <item android:top="0dp" android:bottom="150dp">
        <shape android:shape="rectangle">
            <solid android:color="#E8730A" />
        </shape>
    </item>
    <!-- App icon circle -->
    <item
        android:gravity="center"
        android:width="80dp"
        android:height="80dp">
        <shape android:shape="oval">
            <solid android:color="#E8730A" />
        </shape>
    </item>
    <!-- Inner circle -->
    <item
        android:gravity="center"
        android:width="60dp"
        android:height="60dp">
        <shape android:shape="oval">
            <solid android:color="#1A1A2E" />
            <stroke android:width="2dp" android:color="#C9932A" />
        </shape>
    </item>
</layer-list>
