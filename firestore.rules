rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ⚠️ ADMIN EMAIL CHECK — only these emails can write
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email == "gunayatan.org@gmail.com" ||
        request.auth.token.email == "sachin@ifsjaipur.com" ||
        request.auth.token.email == "admin@munipramansagar.net"
      );
    }

    // Public read, admin write collections
    match /videos/{videoId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /channels/{channelId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /categories/{catId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /homeRows/{rowId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /live/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /config/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /announcements/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /shorts/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /pathshala/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /sections/{sectionId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /playlists/{playlistId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /playlists/{playlistId}/videos/{videoId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /donations/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /curated_nitya_poojan/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /curated_path/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /curated_stotra/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /curated_granth_vachan/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /curated_bhajan/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    // TV link sessions — read public (TV polls), write requires auth (phone links)
    match /tv_sessions/{code} {
      allow read: if true;
      allow create: if true; // TV creates session (no auth on TV)
      allow update: if request.auth != null; // Only authenticated phone can link
      allow delete: if isAdmin();
    }
    // User watch history (only own data)
    match /users/{uid}/watch_history/{videoId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
    // Deny everything else
    match /{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
