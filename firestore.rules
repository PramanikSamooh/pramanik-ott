rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Public read collections (mobile/TV app — no auth required)
    match /videos/{videoId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /channels/{channelId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /categories/{catId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /homeRows/{rowId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /live/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /config/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /announcements/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /shorts/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /pathshala/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /sections/{sectionId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /playlists/{playlistId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /playlists/{playlistId}/videos/{videoId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    // Deny everything else
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
