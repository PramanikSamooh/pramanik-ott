rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Authenticated admin users get full access
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    // Public read for app content (unauthenticated mobile/TV app)
    match /videos/{videoId} {
      allow read: if true;
    }
    match /channels/{channelId} {
      allow read: if true;
    }
    match /categories/{catId} {
      allow read: if true;
    }
    match /homeRows/{rowId} {
      allow read: if true;
    }
    match /live/{docId} {
      allow read: if true;
    }
    match /config/{docId} {
      allow read: if true;
    }
    match /announcements/{docId} {
      allow read: if true;
    }
    match /shorts/{docId} {
      allow read: if true;
    }
    match /pathshala/{document=**} {
      allow read: if true;
    }
  }
}
