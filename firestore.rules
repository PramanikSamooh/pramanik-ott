rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Public read for app content — all writes via Cloud Functions (admin SDK)
    match /videos/{videoId} {
      allow read: if true;
      allow write: if false;
    }
    match /channels/{channelId} {
      allow read: if true;
      allow write: if false;
    }
    match /categories/{catId} {
      allow read: if true;
      allow write: if false;
    }
    match /homeRows/{rowId} {
      allow read: if true;
      allow write: if false;
    }
    match /live/{docId} {
      allow read: if true;
      allow write: if false;
    }
    match /config/{docId} {
      allow read: if true;
      allow write: if false;
    }
    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
